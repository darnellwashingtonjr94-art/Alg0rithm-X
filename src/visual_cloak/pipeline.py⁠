import cv2
import numpy as np
import logging

logger = logging.getLogger(__name__)

class CloakingPipeline:
    def __init__(self, camera_index=0):
        self.cap = cv2.VideoCapture(camera_index)
        self.background_frame = None
        
        # Allow the camera to warm up and capture the static background
        logger.info("Calibrating background for cloaking... please step out of frame.")
        for _ in range(30):
            ret, frame = self.cap.read()
            if ret:
                self.background_frame = np.flip(frame, axis=1)

    def start_stream(self):
        """Executes the optical flow and frame blending loop."""
        if self.background_frame is None:
            logger.error("Failed to capture background. Exiting visual cloak.")
            return

        logger.info("Visual Cloak active. Press 'q' to terminate.")
        
        while self.cap.isOpened():
            ret, frame = self.cap.read()
            if not ret:
                break
                
            frame = np.flip(frame, axis=1)
            
            # Convert to HSV for better color segmentation (e.g., green/red screen cloaking)
            hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)
            
            # Example range for a specific color (adjust for your specific physical cloak)
            lower_bound = np.array([100, 40, 40])
            upper_bound = np.array([100, 255, 255])
            
            # Create a mask for the cloak area
            mask = cv2.inRange(hsv, lower_bound, upper_bound)
            mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, np.ones((3, 3), np.uint8))
            mask = cv2.morphologyEx(mask, cv2.MORPH_DILATE, np.ones((3, 3), np.uint8))
            
            mask_inv = cv2.bitwise_not(mask)
            
            # Segment the background and the foreground
            bg_segment = cv2.bitwise_and(self.background_frame, self.background_frame, mask=mask)
            fg_segment = cv2.bitwise_and(frame, frame, mask=mask_inv)
            
            # Blend
            final_output = cv2.addWeighted(bg_segment, 1, fg_segment, 1, 0)
            
            cv2.imshow("Alg0rithm-X : Cloak View", final_output)
            
            if cv2.waitKey(1) & 0xFF == ord('q'):
                break
                
        self.cap.release()
        cv2.destroyAllWindows()
